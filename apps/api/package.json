{
  "name": "@diceymio/api",
  "version": "0.1.0",
  "private": true,
  "description": "Board Game Ecommerce API",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "prisma generate && tsx watch src/app.ts",
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "start": "node dist/app.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "test": "NODE_ENV=test jest"
  },
  "keywords": [
    "ecommerce",
    "api",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^7.4.2",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.0",
    "pg": "^8.20.0",
    "stripe": "^15.3.0",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.20.0",
    "jest": "^30.2.0",
    "prisma": "^7.4.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
